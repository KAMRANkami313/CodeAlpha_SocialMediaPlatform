{
  "rewrites": [
    { "source": "/sw.js", "destination": "/sw.js" },
    {
      "source": "/workbox-((?:[a-f0-9]+))\\.js",
      "destination": "/workbox-$1.js"
    },
    {
      "source": "/manifest.webmanifest",
      "destination": "/manifest.webmanifest"
    },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/site.webmanifest", "destination": "/site.webmanifest" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    {
      "source": "/((?!api|socket\\.io|sw\\.js|workbox-|manifest\\.webmanifest|robots\\.txt|site\\.webmanifest|sitemap\\.xml).*)",
      "destination": "/"
    }
  ]
}
